<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id ="view_hospital_patient_tree" model= "ir.ui.view">
        <field name ="name">hospital.patient.tree</field>
        <field name ="model">hospital.patient</field>
        <field name= "arch" type= "xml">


            <list string= "Patients">
                <field name= "name"/>
                <field name= "date_of_birth" optional= "show"/>
                <field name= "gender" optional= "hide"/>
            </list>
        </field>    
    </record>    


    <record id ="view_hospital_patient_form" model= "ir.ui.view">
        <field name ="name">hospital.patient.form</field>
        <field name ="model">hospital.patient</field>
        <field name= "arch" type= "xml">


            <form string= "Patients">
               <sheet>
                     <group>
                        <group>
                            <field name= "name"/>
                            <field name= "date_of_birth"/>
                        </group>
                        <group>
                            <field name= "gender"/>
                            <field name= "tag_ids" widget="many2many_tags"/>
                            <field name= "product_ids" widget="many2many_tags"/>
                        </group>
                    </group>
               </sheet>

               <!--mail chatter for tracking in the view-->
                <chatter/>


             
            </form>
        </field>    
    </record>  












    <!--WHhat happens when you click the menu-->
    <!--defining action contains model name as well-->
    <record id="action_hospital_patient" model="ir.actions.act_window">
    <!-->action name-->
    <!--action name appears as the title -->
        <field name="name">Patients</field>
        <!-->model name-->
        <field name= "res_model">hospital.patient</field>
        <!-->view mode-->
        <field name= "view_mode">list,form</field>
         <field name="view_ids" eval="[Command.clear(),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_hospital_patient_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_hospital_patient_form')})
]"/>       
        <!-->help text use for display-->
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new patient
            </p>
        </field>

    </record>
</odoo>