<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id ="view_patient_tag_tree" model= "ir.ui.view">
        <field name ="name">patient.tag.tree</field>
        <field name ="model">patient.tag</field>
        <field name= "arch" type= "xml">


            <list string= "Patient Tags" editable="top">
                <field name= "sequence" widget="handle"/>
                <field name= "name"/>
            </list>
        </field>    
    </record>    














    <!--WHhat happens when you click the menu-->
    <!--defining action contains model name as well-->
    <record id="action_patient_tag" model="ir.actions.act_window">
    <!-->action name-->
        <field name="name">Patient Tags</field>
        <!-->model name-->
        <field name= "res_model">patient.tag</field>
        <!-->view mode-->
        <field name= "view_mode">list</field>
        <!-->help text use for display-->
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new patient tag
            </p>
        </field>

    </record>
</odoo>