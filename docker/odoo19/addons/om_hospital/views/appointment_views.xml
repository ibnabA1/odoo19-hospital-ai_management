<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id ="view_hospital_appointment_tree" model= "ir.ui.view">
        <field name ="name">hospital.appointment.tree</field>
        <field name ="model">hospital.appointment</field>
        <field name= "arch" type= "xml">


            <list string= "Appointments">
                <field name= "reference"/>
                <field name= "patient_id"/>
                <field name= "date_appointment" optional= "show"/>
            </list>
        </field>    
    </record>    

<!-- Appointment Form View -->


    <record id ="view_hospital_appointment_form" model= "ir.ui.view">
        <field name ="name">hospital.appointment.form</field>
        <field name ="model">hospital.appointment</field>
        <field name= "arch" type= "xml">


            <form string= "Appointment">
                <header>
<!--type object means it will call a python function with the specified name-->
                    <!--only show confirm button when state is draft-->
                    <button name="action_confirm" string="Confirm" type="object" invisible="state != 'draft'" class="btn btn-primary"/>
                    <!--only show ongoing button when state is confirmed-->
                    <button name="action_ongoing" string="Ongoing"   type="object" invisible="state != 'confirmed'" class="btn btn-primary"/>
                    <!--only show done button when state is ongoing-->
                    <button name="action_done" string="Done" type="object" invisible="state != 'ongoing'" class="btn btn-primary"/>
                    <!--only show cancel button when state is not done-->
                    <button name="action_cancel" string="Cancel" type="object" invisible="state == 'done' or state == 'cancel'" class="btn btn-primary"/>

                    <button name="action_ask_ai" string="Ask AI" type="object"/>


                          



                    <field name="state" widget="statusbar" statusbar_visible="draft, confirmed, ongoing, done"/>
                </header>
               <sheet>
                     <group>
                        <group>
                            <field name= "reference" readonly="True"/>
                            <field name= "patient_id"/>
                            <field name= "date_appointment"/>
                            <field name="ai_response"/>
                        </group>
                        <group>
                            <field name= "note"/>
                        </group>
                    </group>
                    
               </sheet>

               <!--mail chatter for tracking in the view-->
                <chatter/>


             
            </form>
        </field>    
    </record>  












    <!--WHhat happens when you click the menu-->
    <!--defining action contains model name as well-->
    <record id="action_hospital_appointment" model="ir.actions.act_window">
    <!-->action name-->
        <field name="name">Appointments</field>
        <!-->model name-->
        <field name= "res_model">hospital.appointment</field>
        <!-->view mode-->
        <field name= "view_mode">list,form</field>
         <field name="view_ids" eval="[Command.clear(),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_hospital_appointment_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_hospital_appointment_form')})
]"/>       
        <!-->help text use for display-->
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new appointment
            </p>
        </field>

    </record>
</odoo>