<odoo>
    <data noupdate="1">


    <!--example automatically change the status of the records at regular intervals
    trigger email notifications at regular intervals
    automatically archive and delete the old records to keep database clean-->

    <!--update the status of record every 5 mins-->
    <!--this is the scheduale action defination-->
        <!-- Cron Job Definition -->
        <record id="ir_cron_update_status" model="ir.cron">
        <!--name of the cron-->
            <field name="name">Update Custom Records Status</field>

            <!--the model on which the cron job will act-->
            <field name="model_id" ref="model_custom_record"/>
            <field name="state">code</field>
            <field name="code">model.cron_demo_task_method()</field>

            <!--this sets the cron to run every 5 minutes-->
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>

            <!--anyone can run it any user can run it-->
            <field name="user_id" ref = "base.user_root"></field> <!-- Run indefinitely -->
        </record>
    </data>

</odoo>